%%SELECTOR%% {
    {{ macros.spacing_margin_y(design.spacing) }}
    {{ macros.spacing_padding_all(design.container.padding) }}
    {{ macros.borders(design.container.borders) }}
   
}

%%SELECTOR%% {
  width: {{ design.container.width.style }};
  min-height: {{ design.container.min_height.style }};
  {{ macros.backgroundColor(design.container.background) }}
  {{ macros.spacing_padding_all(design.container.padding) }}
  {{ macros.borders(design.container.borders) }}
  {{ macros.spacing_margin_y(design.spacing) }}
  {{ macros.simpleLayout(design.layout, breakpoint) }}

 

}

%%SELECTOR%% .bde-review-card {
{{ macros.simpleLayout(design.layout, breakpoint) }}

}


{{ macros.fancyBackgroundCss('%%SELECTOR%%', design.background, breakpoint, false, true) }}


{% if design.stars.color_filled %}
%%SELECTOR%% .bde-review-card__star--filled .bde-review-card__star-svg {
    fill: {{ design.stars.color_filled }};
}
{% endif %}

{% if design.stars.color_empty %}
%%SELECTOR%% .bde-review-card__star--empty .bde-review-card__star-svg {
    fill: {{ design.stars.color_empty }};
}
{% endif %}

{% if design.stars.size.style is defined %}
%%SELECTOR%% .bde-review-card__stars {
    font-size: {{ design.stars.size.style }};
}
{% endif %}

{% if design.platform_icon.size.style is defined %}
%%SELECTOR%% .bde-review-card__platform-icon-img {
    width: {{ design.platform_icon.size.style }};
    height: auto;
}
{% endif %}

{% if design.typography.review_text %}
%%SELECTOR%% .bde-review-card__quote {
{{ macros.typography(design.typography.review_text, globalSettings) }}
}
{% endif %}


{% if design.typography.outcome %}
%%SELECTOR%% .bde-review-card__outcome {
 {{ macros.typography(design.typography.outcome, globalSettings) }}
}
{% endif %}

{% if design.typography.customer_name %}
%%SELECTOR%% .bde-review-card__name {
{{ macros.typography(design.typography.customer_name, globalSettings) }}
}
{% endif %}

{% if design.typography.customer_detail %}
%%SELECTOR%% .bde-review-card__detail {
{{ macros.typography(design.typography.customer_detail, globalSettings) }}
}
{% endif %}

{% if design.typography.date %}
%%SELECTOR%% .bde-review-card__date {
{{ macros.typography(design.typography.date, globalSettings) }}
}
{% endif %}

{% if design.typography.platform %}
%%SELECTOR%% .bde-review-card__platform {
{{ macros.typography(design.typography.platform, globalSettings) }}
}
{% endif %}

{% if design.typography.verify_link %}
    %%SELECTOR%% .bde-review-card__verify {
      {{ macros.typography(design.typography.verify_link, globalSettings) }}
    }

    %%SELECTOR%% .bde-review-card__verify:hover {
      {{ macros.typographyWithHoverableColorAndEffects(design.typography.verify_link) }}
    }
    


{% endif %}

{% if design.typography.project_text %}
    %%SELECTOR%% .bde-review-card__project-link {
      {{ macros.typography(design.typography.project_text, globalSettings) }}
    }

    %%SELECTOR%% .bde-review-card__project-link:hover {
      {{ macros.typographyWithHoverableColorAndEffects(design.typography.project_text) }}
    }
    
{% endif %}
