%%SELECTOR%% {
    {{ macros.simpleLayout(design.layout, breakpoint) }}
    {{ macros.spacing_margin_y(design.spacing) }}
    {{ macros.spacing_padding_all(design.container.padding) }}
    {{ macros.borders(design.container.borders) }}
}

{{ macros.layoutV2(design.layout_v2, breakpoint, isBaseBreakpoint, '%%SELECTOR%%') }}
{{ macros.fancyBackgroundCss('%%SELECTOR%%', design.background, breakpoint, false, true) }}

{% if design.platform_icon.size %}
%%SELECTOR%% .bde-aggregate-review__icon-img {
    width: {{ design.platform_icon.size.style }};
    height: auto;
}
{% endif %}

{% if design.stars.size %}
%%SELECTOR%% .bde-aggregate-review__stars {
    font-size: {{ design.stars.size.style }};
}
{% endif %}

{% if design.stars.color_filled %}
%%SELECTOR%% .bde-aggregate-review__star--filled .bde-aggregate-review__star-svg {
    fill: {{ design.stars.color_filled }};
}
{% endif %}


{% if design.text.business_name %}
%%SELECTOR%% .bde-aggregate-review__score,
%%SELECTOR%% .bde-aggregate-review__from,
%%SELECTOR%% .bde-aggregate-review__count,
%%SELECTOR%% .bde-aggregate-review__label,
%%SELECTOR%% .bde-aggregate-review__business {
{{ macros.typography(design.text.business_name, globalSettings) }}
}


{% endif %}

{% if design.text.review_text %}
    %%SELECTOR%% .bde-aggregate-review__link {
      {{ macros.typography(design.text.review_text, globalSettings) }}
width: 100%;
    }

    %%SELECTOR%% .bde-aggregate-review__link:hover {
      {{ macros.typographyWithHoverableColorAndEffects(design.text.review_text) }}
    }
    
{% endif %}
