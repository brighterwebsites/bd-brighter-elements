%%SELECTOR%% {
    {{ macros.spacing_margin_y(design.spacing) }}
}

%%SELECTOR%% .bde-review-card {
    {{ macros.spacing_padding_all(design.container.padding) }}
    {{ macros.borders(design.container.borders) }}
    {% if design.container.gap.style is defined and design.container.gap.style %}gap: {{ design.container.gap.style }};{% endif %}
}

{{ macros.fancyBackgroundCss('%%SELECTOR%% .bde-review-card', design.container.background, breakpoint, false, true) }}

{% if design.stars.color_filled %}
%%SELECTOR%% .bde-review-card__star--filled .bde-review-card__star-svg {
    fill: {{ design.stars.color_filled }};
}
{% endif %}

{% if design.stars.color_empty %}
%%SELECTOR%% .bde-review-card__star--empty .bde-review-card__star-svg {
    fill: {{ design.stars.color_empty }};
}
{% endif %}

{% if design.stars.size.style is defined %}
%%SELECTOR%% .bde-review-card__stars {
    font-size: {{ design.stars.size.style }};
}
{% endif %}

{% if design.platform_icon.size.style is defined %}
%%SELECTOR%% .bde-review-card__platform-icon-img {
    width: {{ design.platform_icon.size.style }};
    height: auto;
}
{% endif %}

{% if design.typography.quote %}
{{ macros.typography('%%SELECTOR%% .bde-review-card__quote', design.typography.quote, breakpoint) }}
{% endif %}

{% if design.typography.outcome %}
{{ macros.typography('%%SELECTOR%% .bde-review-card__outcome', design.typography.outcome, breakpoint) }}
{% endif %}

{% if design.typography.author %}
{{ macros.typography('%%SELECTOR%% .bde-review-card__name, %%SELECTOR%% .bde-review-card__detail', design.typography.author, breakpoint) }}
{% endif %}

{% if design.typography.meta %}
{{ macros.typography('%%SELECTOR%% .bde-review-card__platform, %%SELECTOR%% .bde-review-card__date', design.typography.meta, breakpoint) }}
{% endif %}

{% if design.typography.links %}
{{ macros.typography('%%SELECTOR%% .bde-review-card__verify, %%SELECTOR%% .bde-review-card__project-link', design.typography.links, breakpoint) }}
{% endif %}
