# Copy to deploy.env and fill in (deploy.env is gitignored).
# Used by: scripts/deploy.sh  |  alias: deploy-bd-bw

# --- SSH ---
SSH_HOST="host.bweb1.com.au"
SSH_USER="your_cyberpanel_ssh_user"
SSH_PORT="22"

# Full path to the plugin folder ON THE SERVER (trailing slash optional).
# Example CyberPanel:
# REMOTE_PLUGIN_PATH="/home/yoursite.com.au/public_html/wp-content/plugins/bd-brighter-elements"
REMOTE_PLUGIN_PATH="/home/DOMAIN/public_html/wp-content/plugins/bd-brighter-elements"

# Git branch to deploy (must exist on origin).
DEPLOY_BRANCH="claude/breakdance-cpt-submissions-3qVD8"

# Set to 1 to print commands only.
DRY_RUN="0"

# Set to 1 to run: cp -a plugin plugin.bak-YYYYMMDD-HHMMSS on server before deploy (large; usually off).
REMOTE_BACKUP="0"

# PuTTY plink deploy (no ssh-agent): full path to .ppk
# PPK_PATH="C:/Users/vanes/.ssh/your-key.ppk"
